APP_NAME="Sistema EPP Backend"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=sistema_epp

# Local development example only. Use a unique long secret outside development.
JWT_SECRET_KEY=change-this-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DETECTOR_MODEL_PATH=../Detector/best.pt
DETECTOR_CONFIDENCE=0.5
DETECTOR_ENABLED=true
DETECTOR_FRAME_SKIP=5
DETECTOR_SAVE_INTERVAL_SECONDS=10

UPLOAD_DIR=storage/uploads
ANNOTATED_DIR=storage/annotated

DEFAULT_ADMIN_EMAIL=admin@empresa.com
# Local development example only. Use a strong password outside development.
DEFAULT_ADMIN_PASSWORD=password123
DEFAULT_ADMIN_NAME=Administrador
